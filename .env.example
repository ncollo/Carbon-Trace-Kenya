# ============================================================================
# Carbon Trace Kenya - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values for local development
# For production, use secure secret management (AWS Secrets Manager, etc.)
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Carbon Trace Kenya
APP_ENV=development
DEBUG=True

# ============================================================================
# DATABASE - PostgreSQL (Primary)
# ============================================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carbon_trace_kenya
DATABASE_ECHO=False

# ============================================================================
# REDIS - Background Jobs & Caching
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ============================================================================
# AWS / S3 CONFIGURATION
# ============================================================================
USE_S3=False
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=carbon-trace-uploads
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key

# Alternative: Supabase Storage
USE_SUPABASE=False
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_BUCKET=carbon-trace-uploads

# ============================================================================
# BACKGROUND WORKER CONFIGURATION
# ============================================================================
WORKER_ENABLED=True
WORKER_QUEUES=default,ingestion,calculations
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=INFO
WORKER_METRICS_PORT=8001

# ============================================================================
# FRONTEND / CORS
# ============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# ============================================================================
# EMAIL / NOTIFICATIONS (Optional)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@carbontrace.ke
SMTP_FROM_NAME=Carbon Trace Kenya

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# ============================================================================
# ML MODEL PATHS
# ============================================================================
ANOMALY_MODEL_PATH=models/isolation_forest_anomaly.pkl
EMISSION_PREDICTOR_PATH=models/emission_predictor.pkl
POLICY_IMPACT_MODEL_PATH=models/policy_impact_simulator.pkl

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_ANOMALY_DETECTION=True
ENABLE_POLICY_SIMULATION=True
ENABLE_XBRL_EXPORT=True
ENABLE_RECONCILIATION=True

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
RELOAD=True
HOST=0.0.0.0
PORT=8000

# ============================================================================
# TESTING (used by pytest)
# ============================================================================
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/carbon_trace_test
REDIS_URL_TEST=redis://localhost:6379/1
